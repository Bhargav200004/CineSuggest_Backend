# Database Configuration
# For local development, use SQLite:
DATABASE_URL=sqlite:///./movies.db

# For production (Supabase PostgreSQL), use:
# DATABASE_URL=DATABASE_URL=postgresql://postgres:{project passord}@db.{project id}.supabase.co:5432/postgres?sslmode=require

# JWT Authentication
SECRET_KEY=development-secret-key-change-in-production-9876543210
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# TMDb API Key (for loading movie data)
TMDB_API_KEY={TMDB_API_KEY}
